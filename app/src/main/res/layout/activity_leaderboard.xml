<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/backButton"
        style="@style/Widget.MazeGame.OutlinedButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="start"
        android:padding="6dp"
        android:backgroundTint="@color/frame_bg"
        app:icon="@drawable/ic_chevron_left"
        app:iconGravity="textStart"
        android:contentDescription="@string/back_home" />

    <TextView
        android:id="@+id/leaderboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/leaderboard_title"
        android:textColor="@color/accent_gold"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_game_frame"
        android:padding="12dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/leaderboardList"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/leaderboardEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/leaderboard_empty"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>